generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: Prisma schema is synced from Supabase migrations
// This is a reference schema. Use 'prisma db push' to keep in sync
// or 'prisma migrate dev' to create new migrations

model categorias {
  id        String   @id @default(cuid())
  user_id   String
  nombre    String
  tipo      String
  color     String?
  prioridad String?
  activo    Boolean  @default(true)
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([activo])
}

model movimientos {
  id          String   @id @default(cuid())
  user_id     String
  fecha       String
  concepto    String
  monto       Decimal
  tipo        String   // Ingreso, Gasto
  categoria   String?
  cuota       Int?
  descripcion String?
  activo      Boolean  @default(true)
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([fecha])
  @@index([activo])
}

model ingresos {
  id          String   @id @default(cuid())
  user_id     String
  concepto    String
  monto       Decimal
  fecha_cobro String
  frecuencia  String   // Mensual, etc
  activo      Boolean  @default(true)
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([activo])
}

model metas {
  id            String   @id @default(cuid())
  user_id       String
  nombre        String
  monto_objetivo Decimal
  monto_actual  Decimal  @default(0)
  fecha_target  String?
  activo        Boolean  @default(true)
  created_at    DateTime @default(now())

  @@index([user_id])
  @@index([activo])
}

model profiles {
  id              String   @id
  user_id         String
  pay_day         Int      @default(1)
  salary          Decimal  @default(0)
  saving_target   Decimal  @default(0)
  financial_center String  @default("Buenos Aires")
  created_at      DateTime @default(now())

  @@unique([user_id])
  @@index([user_id])
}
