SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Opcional: habilita la Carga rápida por IA en Movimientos. Sin esta clave,
# ese botón sigue apareciendo pero avisa que todavía no está configurada
# (nunca rompe el resto de la app). Nunca con prefijo VITE_ — nunca debe
# llegar al navegador.
ANTHROPIC_API_KEY=

# Notificaciones de vencimientos próximos (cron diario, ver vercel.json y
# src/lib/notifications.functions.ts). Cada una es opcional por separado:
# sin RESEND_API_KEY no se manda email, sin las VAPID_* no se manda push,
# sin CRON_SECRET el endpoint rechaza cualquier llamada.
#
# - CRON_SECRET: protege /cron-notificaciones. Vercel lo agrega solo como
#   header "Authorization: Bearer <CRON_SECRET>" en cada invocación del cron
#   SI esta env var está configurada en el proyecto de Vercel.
# - RESEND_API_KEY: cuenta en https://resend.com (capa gratis alcanza).
# - VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY: par de claves para Web Push,
#   generado con `npx web-push generate-vapid-keys` (no requiere cuenta).
#   VITE_VAPID_PUBLIC_KEY debe tener el MISMO valor que VAPID_PUBLIC_KEY
#   (la pública sí puede viajar al navegador, la privada nunca).
# - EMAIL_FROM: remitente del mail. Sin configurar, usa el sandbox de Resend
#   (onboarding@resend.dev) — anda pero llega marcado como "vía resend.dev".
CRON_SECRET=
RESEND_API_KEY=
EMAIL_FROM=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=
